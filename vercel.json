{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/hrms1/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/hrms1/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/hrms1/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/hrms1/",
      "permanent": false
    },
    {
      "source": "/hrms1",
      "destination": "/hrms1/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/hrms1/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/hrms1/icons/(.*)",
      "destination": "/icons/$1"
    },
    {
      "source": "/hrms1/data/(.*)",
      "destination": "/data/$1"
    },
    {
      "source": "/hrms1/config/(.*)",
      "destination": "/config/$1"
    },
    {
      "source": "/hrms1/logo.png",
      "destination": "/logo.png"
    },
    {
      "source": "/hrms1/manifest.webmanifest",
      "destination": "/manifest.webmanifest"
    },
    {
      "source": "/hrms1/registerSW.js",
      "destination": "/registerSW.js"
    },
    {
      "source": "/hrms1/sw.js",
      "destination": "/sw.js"
    },
    {
      "source": "/hrms1/workbox-(.*).js",
      "destination": "/workbox-$1.js"
    },
    {
      "source": "/hrms1",
      "destination": "/index.html"
    },
    {
      "source": "/hrms1/(.*)",
      "destination": "/index.html"
    }
  ]
}
